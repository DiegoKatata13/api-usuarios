# Variáveis de Ambiente - Exemplo
# Copie este arquivo para .env e preencha com seus valores reais

# Ambiente da aplicação (development, test, production)
NODE_ENV=development

# Porta do servidor
PORT=3000

# MongoDB - URI de conexão
MONGODB_URI=mongodb://localhost:27017/api-usuarios

# JWT - Configuração de tokens
JWT_SECRET=sua-chave-secreta-super-segura-aqui-mude-em-producao
JWT_EXPIRES_IN=24h

# CORS - Origens permitidas (separadas por vírgula)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Logging - Nível de log (debug, info, warn, error)
LOG_LEVEL=info
